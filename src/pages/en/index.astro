---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Stats from '../../components/Stats.astro';

const title = 'Momchil Stepanov — Voice talent, narrator, audiobook producer';
const description =
  'Voice for advertising, documentary, dubbing and audiobooks. Over 200 audiobooks, 5,000+ documentary productions, hundreds of films and series in dubbing. Top 3 narrator on Storytel BG 2025.';

const stats = [
  { number: '200', sup: '+', label: 'Audiobooks' },
  { number: '5,000', sup: '+', label: 'Documentary' },
  { number: '№3', label: 'Storytel BG 2025' },
  { number: '20', sup: '+', label: 'Years experience' },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalPath="/en"
  includePersonSchema={true}
  immersiveHero={true}
>
  <section class="hero">
    <div class="hero-image" aria-hidden="true"></div>
    <div class="side-marker" aria-hidden="true">MS — Sofia, Bulgaria</div>
    <div class="hero-content">
      <p class="eyebrow eyebrow--marked">Voice talent · Narrator · Producer</p>
      <h1 class="hero-title">A voice for <em>stories</em> that endure.</h1>
      <p class="hero-lead muted">
        Voice services across advertising, documentary, dubbing and audiobooks. From production for Bulgarian publishers to international projects.
      </p>
      <a href="/en/services/voice-over" class="btn">
        <span>Listen to demo</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <Stats items={stats} />

  <section class="services">
    <div class="container">
      <header class="section-header reveal">
        <h2 class="section-title">What I <em>offer</em></h2>
        <p class="section-intro muted">
          A voice with broad range — from intimate narration to dramatic dubbing, from corporate voice over to full audiobook production.
        </p>
      </header>

      <div class="service-grid reveal">
        <ServiceCard
          number="01"
          slug="Voice Over"
          title="Voice Over"
          description="Advertising, documentary, corporate, e-learning. Studio quality, fast turnaround."
          href="/en/services/voice-over"
          cta="View more"
        />
        <ServiceCard
          number="02"
          slug="Audiobooks"
          title="Audiobooks"
          description="End-to-end production. Provide the text, receive a finished book — narrator and executive producer in one."
          href="/en/services/audiobooks"
          cta="View more"
          flagship
          flagshipLabel="Flagship"
        />
        <ServiceCard
          number="03"
          slug="Dubbing"
          title="Dubbing"
          description="Dubbing and voice acting for film, television, animation. Track record with leading Bulgarian studios."
          href="/en/services/dubbing"
          cta="View more"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    height: 100vh;
    min-height: 700px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    position: relative;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    right: 0;
    top: 0;
    width: 55%;
    height: 100%;
    background-image: url('/portrait.jpg');
    background-size: cover;
    background-position: center top;
    mask-image: linear-gradient(90deg, transparent 0%, black 25%, black 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 25%, black 100%);
  }

  .side-marker {
    position: absolute;
    left: var(--sp-7);
    bottom: var(--sp-8);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0.6;
    z-index: 2;
  }

  .hero-content {
    grid-column: 1;
    padding: 0 var(--sp-7) var(--sp-10) var(--container-padding);
    position: relative;
    z-index: 2;
    max-width: 640px;
  }

  .eyebrow { margin-bottom: var(--sp-6); }
  .hero-title { margin-bottom: var(--sp-6); }
  .hero-lead {
    font-size: var(--fs-md);
    line-height: 1.5;
    max-width: 30rem;
    margin-bottom: var(--sp-8);
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 0;
      padding-top: var(--sp-11);
    }
    .hero-image {
      position: relative;
      width: 100%;
      height: 60vh;
      min-height: 360px;
      mask-image: linear-gradient(180deg, black 0%, black 70%, transparent 100%);
      -webkit-mask-image: linear-gradient(180deg, black 0%, black 70%, transparent 100%);
    }
    .hero-content {
      grid-column: 1;
      padding: var(--sp-8) var(--container-padding) var(--sp-9);
      max-width: none;
    }
    .side-marker { display: none; }
  }

  .services {
    padding-block: var(--sp-10);
    border-top: 1px solid var(--line);
  }

  .section-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-8);
    margin-bottom: var(--sp-10);
    align-items: end;
  }

  .section-title { font-size: var(--fs-2xl); line-height: 1; }
  .section-intro {
    font-size: var(--fs-base);
    line-height: 1.7;
    max-width: 32rem;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  @media (max-width: 900px) {
    .section-header {
      grid-template-columns: 1fr;
      gap: var(--sp-4);
      margin-bottom: var(--sp-8);
    }
    .service-grid { grid-template-columns: 1fr; }
  }
</style>
