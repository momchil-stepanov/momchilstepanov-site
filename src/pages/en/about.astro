---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
---

<BaseLayout
  title="About Momchil Stepanov — Biography"
  description="Momchil Stepanov — actor, singer, voice talent, producer. Over 200 audiobooks, 5,000+ documentary productions, hundreds of feature and animated films and series."
  lang="en"
  canonicalPath="/en/about"
>
  <Section as="article">
    <Container>
      <header class="page-header reveal">
        <p class="eyebrow">About</p>
        <h1>Momchil Stepanov</h1>
        <p class="lead muted">
          Actor, singer, voice talent and producer. A complete performer with deep experience across genres and formats.
        </p>
      </header>

      <div class="bio-grid">
        <aside class="portrait reveal" aria-hidden="true">
          <div class="portrait-placeholder">
            <span class="muted">[Portrait — TBD]</span>
          </div>
        </aside>

        <div class="bio-content">
          <section class="reveal">
            <h2>Professional scope</h2>
            <p>
              Career in acting, singing, voice work and audio production. Portfolio includes hundreds of feature and animated films and series, over 5,000 documentary productions, and over 200 audiobooks.
            </p>
            <p>
              Top 3 narrator on Storytel BG for 2025. Experience with leading Bulgarian production and recording studios.
            </p>
          </section>

          <section class="reveal">
            <h2>Acting and stage</h2>
            <p class="muted">
              Theatre and screen training, followed by a professional career on stage and in studio. Lead and supporting roles in hundreds of feature and animated films and series — the accumulated acting experience informs every voice over interpretation.
            </p>
          </section>

          <section class="reveal">
            <h2>Music</h2>
            <p class="muted">
              Original music and songs for Bulgarian adaptations of animated films. Live performance. Details on the <a href="/en/music" class="link">Music</a> page.
            </p>
          </section>
        </div>
      </div>

      <section class="clients reveal" aria-labelledby="clients-heading">
        <h2 id="clients-heading">Selected Clients</h2>
        <p class="muted">
          Publishers, production houses and studios with established working relationships. Listed in text form only.
        </p>
        <div class="clients-placeholder">
          <span class="muted">[Client logos/names — TBD]</span>
        </div>
      </section>

      <div class="cta-row reveal">
        <Button href="/en/contact" variant="primary">Get in touch</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-header { max-width: 820px; margin-bottom: var(--sp-7); }
  .page-header h1 { margin-block: var(--sp-3) var(--sp-4); }
  .lead { font-size: var(--fs-md); }

  .bio-grid {
    display: grid; grid-template-columns: 1fr 2fr;
    gap: var(--sp-7); margin-bottom: var(--sp-8);
  }

  @media (max-width: 900px) {
    .bio-grid { grid-template-columns: 1fr; gap: var(--sp-6); }
  }

  .portrait-placeholder {
    aspect-ratio: 3 / 4;
    background: var(--bg-elevated);
    color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--line);
  }

  .bio-content section + section { margin-top: var(--sp-7); }
  .bio-content h2 { font-size: var(--fs-lg); margin-bottom: var(--sp-4); }
  .bio-content p + p { margin-top: var(--sp-3); }

  .clients {
    border-top: 1px solid var(--line);
    padding-top: var(--sp-8);
    margin-top: var(--sp-9);
  }
  .clients h2 { margin-bottom: var(--sp-4); }
  .clients-placeholder {
    border: 1px dashed var(--line);
    background: var(--bg-elevated);
    color: var(--muted);
    padding: var(--sp-7) var(--sp-6); text-align: center;
    margin-top: var(--sp-5);
  }

  .cta-row { margin-top: var(--sp-9); }
</style>
