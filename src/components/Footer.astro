---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { profiles } from '../data/profiles';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = `/${lang}`;
const year = new Date().getFullYear();

const navLinks = [
  { label: t('nav.home'), href: base },
  { label: t('nav.services.voiceOver'), href: `${base}/services/voice-over` },
  { label: t('nav.services.audiobooks'), href: `${base}/services/audiobooks` },
  { label: t('nav.services.dubbing'), href: `${base}/services/dubbing` },
  { label: t('nav.music'), href: `${base}/music` },
  { label: t('nav.about'), href: `${base}/about` },
  { label: t('nav.contact'), href: `${base}/contact` },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col footer-col--brand">
      <p class="brand">Момчил Степанов</p>
      <p class="brand-role">{t('site.tagline')}</p>
    </div>

    <div class="footer-col">
      <h6 class="footer-heading eyebrow eyebrow--marked">{t('footer.navigation')}</h6>
      <ul class="footer-list">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h6 class="footer-heading eyebrow eyebrow--marked">{t('footer.profiles')}</h6>
      <ul class="footer-list">
        {
          profiles.map((profile) => (
            <li>
              <a
                href={profile.url}
                class="footer-link"
                target="_blank"
                rel="noopener noreferrer"
              >
                {profile.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="footer-copy">© {year} Момчил Степанов · {t('footer.rights')}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--sp-10);
    padding-block: var(--sp-9) var(--sp-6);
    border-top: 1px solid var(--line);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: var(--sp-9);
    padding-bottom: var(--sp-9);
  }

  .footer-col--brand .brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: var(--sp-2);
  }

  .footer-col--brand .brand-role {
    font-size: var(--fs-sm);
    color: var(--muted);
    max-width: 32ch;
  }

  .footer-heading {
    margin-bottom: var(--sp-5);
  }

  .footer-list {
    display: grid;
    gap: var(--sp-3);
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    color: var(--fg);
    opacity: 0.7;
    transition: opacity var(--t-fast);
  }

  .footer-link:hover {
    opacity: 1;
  }

  .footer-bottom {
    padding-top: var(--sp-6);
    border-top: 1px solid var(--line);
  }

  .footer-copy {
    font-size: var(--fs-xs);
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--sp-7);
    }
  }
</style>
