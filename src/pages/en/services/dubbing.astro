---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Section from '../../../components/Section.astro';
import Button from '../../../components/Button.astro';
---

<BaseLayout
  title="Dubbing — Momchil Stepanov"
  description="Dubbing and voice acting for film, television and animation. Track record with leading Bulgarian studios — Medialink, Andarta, Doli, VMS, BNT."
  lang="en"
  canonicalPath="/en/services/dubbing"
>
  <Section as="article">
    <Container>
      <header class="page-header reveal">
        <p class="eyebrow">Services · Dubbing</p>
        <h1>Dubbing</h1>
        <p class="lead muted">
          Dubbing and voice acting for feature film, television and animation. Hundreds of projects with leading Bulgarian studios.
        </p>
      </header>

      <div class="content-grid">
        <section class="reveal">
          <h2>Formats</h2>
          <ul class="bullets">
            <li>Feature film and television (lip-sync dubbing)</li>
            <li>Documentary (voice-over on original)</li>
            <li>Animation (character voices)</li>
            <li>Reality TV and factual formats</li>
            <li>Trailers and promotional materials</li>
          </ul>
        </section>

        <section class="reveal">
          <h2>Partner studios</h2>
          <ul class="bullets">
            <li>Medialink</li>
            <li>Andarta</li>
            <li>Doli Media Studio</li>
            <li>VMS</li>
            <li>BNT (Bulgarian National Television)</li>
          </ul>

          <h2>Roles</h2>
          <p class="muted">
            Voice actor (lead and supporting), ensemble performer, dubbing director on request.
          </p>
        </section>
      </div>

      <section class="placeholder-section reveal">
        <h2>Reel and selected projects</h2>
        <div class="reel-placeholder">
          <span class="muted">[Dubbing showreel and selected projects — TBD]</span>
        </div>
      </section>

      <div class="cta-row reveal">
        <Button href="/en/contact" variant="primary">Send inquiry</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-header { max-width: 820px; margin-bottom: var(--sp-9); }
  .page-header h1 { margin-block: var(--sp-3) var(--sp-5); }
  .lead { font-size: var(--fs-md); }
  .content-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: var(--sp-8); margin-bottom: var(--sp-9);
  }
  @media (max-width: 767px) {
    .content-grid { grid-template-columns: 1fr; gap: var(--sp-6); }
  }
  .content-grid h2 { font-size: var(--fs-lg); margin-bottom: var(--sp-4); }
  .content-grid h2:not(:first-of-type) { margin-top: var(--sp-6); }
  .bullets { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--sp-2); }
  .bullets li { padding-left: var(--sp-5); position: relative; color: var(--muted); }
  .bullets li::before { content: '—'; position: absolute; left: 0; color: var(--fg); }
  .placeholder-section h2 { margin-bottom: var(--sp-4); }
  .reel-placeholder {
    border: 1px dashed var(--line);
    padding: var(--sp-7) var(--sp-6); text-align: center;
    aspect-ratio: 16 / 6;
    display: flex; align-items: center; justify-content: center;
  }
  .cta-row { margin-top: var(--sp-9); }
</style>
