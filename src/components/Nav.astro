---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = `/${lang}`;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

interface NavItem {
  label: string;
  href: string;
  children?: NavItem[];
}

const items: NavItem[] = [
  { label: t('nav.home'), href: `${base}` },
  {
    label: t('nav.services'),
    href: `${base}/services/advertising`,
    children: [
      { label: t('nav.services.advertising'), href: `${base}/services/advertising` },
      { label: t('nav.services.voiceOver'), href: `${base}/services/voice-over` },
      { label: t('nav.services.audiobooks'), href: `${base}/services/audiobooks` },
    ],
  },
  { label: t('nav.music'), href: `${base}/music` },
  { label: t('nav.about'), href: `${base}/about` },
  { label: t('nav.contact'), href: `${base}/contact` },
];

function isActive(href: string): boolean {
  if (href === base) return currentPath === base || currentPath === `${base}/`;
  return currentPath.startsWith(href);
}
---

<nav class="nav" aria-label="Primary">
  <ul class="nav-list">
    {
      items.map((item) => (
        <li class={`nav-item ${item.children ? 'has-children' : ''}`}>
          <a
            href={item.href}
            class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}
            aria-haspopup={item.children ? 'true' : undefined}
          >
            {item.label}
          </a>
          {item.children && (
            <ul class="nav-submenu" role="menu">
              {item.children.map((child) => (
                <li role="none">
                  <a
                    href={child.href}
                    role="menuitem"
                    class={`nav-sublink ${isActive(child.href) ? 'is-active' : ''}`}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .nav-list {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg);
    opacity: 0.7;
    padding: var(--sp-3) 0;
    display: inline-block;
    transition: opacity var(--t-base);
  }

  .nav-link:hover,
  .nav-link.is-active {
    opacity: 1;
  }

  .nav-submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding: var(--sp-3);
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    min-width: 220px;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--t-base), visibility var(--t-base);
    z-index: 10;
  }

  .has-children:hover .nav-submenu,
  .has-children:focus-within .nav-submenu {
    opacity: 1;
    visibility: visible;
  }

  .nav-sublink {
    display: block;
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg);
    opacity: 0.7;
    white-space: nowrap;
    transition: opacity var(--t-fast), background var(--t-fast);
  }

  .nav-sublink:hover,
  .nav-sublink.is-active {
    opacity: 1;
    background: var(--bg);
  }

  @media (max-width: 900px) {
    .nav-list {
      gap: var(--sp-5);
      flex-wrap: wrap;
      justify-content: center;
      order: 3;
      width: 100%;
    }

    .nav-link {
      padding: var(--sp-2) 0;
    }

    .nav-submenu {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      display: none;
      border: none;
      background: transparent;
      padding: var(--sp-2) 0;
      min-width: 0;
    }

    .has-children:hover .nav-submenu,
    .has-children:focus-within .nav-submenu {
      display: block;
    }
  }
</style>
