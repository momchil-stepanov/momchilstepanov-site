---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Nav from './Nav.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeHref = `/${lang}`;
---

<header class="site-header">
  <div class="header-inner">
    <a href={homeHref} class="brand" aria-label={t('site.title')}>
      <span>Момчил Степанов</span>
    </a>
    <Nav />
    <LanguageSwitcher />
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0.9) 0%, rgba(10, 10, 10, 0) 100%);
    pointer-events: none;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-5) var(--container-padding);
    gap: var(--sp-7);
    max-width: var(--container-max);
    margin: 0 auto;
    pointer-events: auto;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--fg);
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .header-inner {
      padding-block: var(--sp-4);
      flex-wrap: wrap;
      gap: var(--sp-3);
    }

    .brand {
      font-size: 1.125rem;
    }
  }
</style>
