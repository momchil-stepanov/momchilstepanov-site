---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Section from '../../../components/Section.astro';
import Button from '../../../components/Button.astro';
---

<BaseLayout
  title="Дублаж — Момчил Степанов"
  description="Дублаж и озвучаване на филми, сериали и анимация. Опит с водещите български студия — Медиалинк, Андарта, Доли, VMS, БНТ."
  lang="bg"
  canonicalPath="/bg/services/dubbing"
>
  <Section as="article">
    <Container>
      <header class="page-header reveal">
        <p class="eyebrow">Услуги · Дублаж</p>
        <h1>Дублаж</h1>
        <p class="lead muted">
          Дублаж и озвучаване на игрални филми, сериали и анимация. Стотици проекти с водещите български студия.
        </p>
      </header>

      <div class="content-grid">
        <section class="reveal">
          <h2>Формати</h2>
          <ul class="bullets">
            <li>Игрални филми и сериали (lip-sync дублаж)</li>
            <li>Документални филми (voice-over върху оригинал)</li>
            <li>Анимация (характерни гласове)</li>
            <li>Reality TV и факт формати</li>
            <li>Trailer-и и промо материали</li>
          </ul>
        </section>

        <section class="reveal">
          <h2>Партньорски студия</h2>
          <ul class="bullets">
            <li>Медиалинк</li>
            <li>Андарта</li>
            <li>Доли Медиа Студио</li>
            <li>VMS</li>
            <li>БНТ</li>
          </ul>

          <h2>Роли</h2>
          <p class="muted">
            Voice actor (главни и поддържащи роли), ансамблов изпълнител, режисьор на дублаж при заявка.
          </p>
        </section>
      </div>

      <section class="placeholder-section reveal">
        <h2>Реел и избрани проекти</h2>
        <div class="reel-placeholder">
          <span class="muted">[Дублажен showreel и избрани проекти — TBD]</span>
        </div>
      </section>

      <div class="cta-row reveal">
        <Button href="/bg/contact" variant="primary">Запитване</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-header {
    max-width: 820px;
    margin-bottom: var(--sp-9);
  }

  .page-header h1 {
    margin-block: var(--sp-3) var(--sp-5);
  }

  .lead {
    font-size: var(--fs-md);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
    margin-bottom: var(--sp-9);
  }

  @media (max-width: 767px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-6);
    }
  }

  .content-grid h2 {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-4);
  }

  .content-grid h2:not(:first-of-type) {
    margin-top: var(--sp-6);
  }

  .bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-2);
  }

  .bullets li {
    padding-left: var(--sp-5);
    position: relative;
    color: var(--muted);
  }

  .bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--fg);
  }

  .placeholder-section h2 {
    margin-bottom: var(--sp-4);
  }

  .reel-placeholder {
    border: 1px dashed var(--line);
    background: var(--bg-elevated);
    color: var(--muted);
    padding: var(--sp-7) var(--sp-6);
    text-align: center;
    aspect-ratio: 16 / 6;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta-row {
    margin-top: var(--sp-9);
  }
</style>
