---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Nav from './Nav.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import MobileMenu from './MobileMenu.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeHref = `/${lang}`;
---

<header class="site-header">
  <div class="header-inner">
    <a href={homeHref} class="brand" aria-label={t('site.title')}>
      <span>Момчил Степанов</span>
    </a>
    <div class="header-end header-end--desktop">
      <Nav />
      <LanguageSwitcher />
    </div>
    <div class="header-end header-end--mobile">
      <MobileMenu />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0.9) 0%, rgba(10, 10, 10, 0) 100%);
    pointer-events: none;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-5) var(--container-padding);
    gap: var(--sp-7);
    max-width: var(--container-max);
    margin: 0 auto;
    pointer-events: auto;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--fg);
    white-space: nowrap;
    z-index: 60;
    position: relative;
  }

  .header-end {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
  }

  .header-end--desktop {
    display: flex;
  }

  .header-end--mobile {
    display: none;
  }

  @media (max-width: 900px) {
    .header-inner {
      padding-block: var(--sp-4);
    }

    .brand {
      font-size: 1.125rem;
    }

    .header-end--desktop {
      display: none;
    }

    .header-end--mobile {
      display: flex;
    }
  }
</style>
