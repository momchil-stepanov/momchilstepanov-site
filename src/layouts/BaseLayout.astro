---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath: string;
  includePersonSchema?: boolean;
  ogImage?: string;
  /** Hide header (e.g. for hero-immersive pages). Default false. */
  hideHeader?: boolean;
  /**
   * Set to true on pages where the hero is immersive (e.g. home) and
   * already accounts for the fixed header. Default false adds top
   * padding so content clears the header.
   */
  immersiveHero?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  includePersonSchema,
  ogImage,
  hideHeader = false,
  immersiveHero = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang === 'bg' ? 'bg-BG' : 'en-US'}>
  <head>
    <BaseHead
      title={title}
      description={description}
      lang={lang}
      canonicalPath={canonicalPath}
      includePersonSchema={includePersonSchema}
      ogImage={ogImage}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    {!hideHeader && <Header />}
    <main id="main" class={immersiveHero ? 'main--immersive' : 'main--padded'}>
      <slot />
    </main>

    <style>
      .main--padded {
        padding-top: 5rem;
      }
      @media (max-width: 900px) {
        .main--padded {
          padding-top: 8rem; /* header wraps to multiple rows on mobile */
        }
      }
    </style>
    <Footer />

    <script>
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
