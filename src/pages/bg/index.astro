---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Stats from '../../components/Stats.astro';

const title = 'Момчил Степанов — Voice talent, наратор, продуцент на аудиокниги';
const description =
  'Глас за реклами, документални филми и аудиокниги. Над 200 аудиокниги, 5000+ документални продукции, стотици филми и сериали. Top 3 наратор в Storytel BG 2025.';

const stats = [
  { number: '200', sup: '+', label: 'Аудиокниги' },
  { number: '5 000', sup: '+', label: 'Документални' },
  { number: '№3', label: 'Storytel BG 2025' },
  { number: '20', sup: '+', label: 'Години опит' },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="bg"
  canonicalPath="/bg"
  includePersonSchema={true}
  immersiveHero={true}
>
  {/* ===================== HERO ===================== */}
  <section class="hero">
    <div class="hero-image" aria-hidden="true"></div>
    <div class="side-marker" aria-hidden="true">MS — Sofia, Bulgaria</div>
    <div class="hero-content">
      <p class="eyebrow eyebrow--marked">Voice talent · Narrator · Producer</p>
      <h1 class="hero-title">Глас за <em>истории</em>, които остават.</h1>
      <p class="hero-lead muted">
        Гласовите ми услуги обхващат реклами, документални филми и аудиокниги. От продукция за български издатели до международни проекти.
      </p>
      <a href="/bg/services/voice-over" class="btn">
        <span>Чуй демото</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  {/* ===================== STATS ===================== */}
  <Stats items={stats} />

  {/* ===================== SERVICES ===================== */}
  <section class="services">
    <div class="container">
      <header class="section-header reveal">
        <h2 class="section-title">Какво <em>предлагам</em></h2>
        <p class="section-intro muted">
          Гласът ми е инструмент с широк регистър — от интимна нарация до енергична рекламна интерпретация, от корпоративен voice over до пълно audiobook продуциране.
        </p>
      </header>

      <div class="service-grid reveal">
        <ServiceCard
          number="01"
          slug="Advertising"
          title="Реклами"
          description="VO за телевизионни и радио реклами, jingles, кратки и дълги формати. Български и международни брандове."
          href="/bg/services/advertising"
          cta="Виж повече"
        />
        <ServiceCard
          number="02"
          slug="Voice Over"
          title="Глас зад кадър"
          description="Документални филми, корпоративни видеа, e-learning, презентации. Студийно качество, бърз turnaround."
          href="/bg/services/voice-over"
          cta="Виж повече"
        />
        <ServiceCard
          number="03"
          slug="Audiobooks"
          title="Аудиокниги"
          description="End-to-end продукция. Давате текста, получавате готовата книга — наратор и изпълнителен продуцент в едно."
          href="/bg/services/audiobooks"
          cta="Виж повече"
          flagship
          flagshipLabel="Флагман"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    height: 100vh;
    min-height: 700px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    position: relative;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    right: 0;
    top: 0;
    width: 55%;
    height: 100%;
    background-image: url('/portrait.jpg');
    background-size: cover;
    background-position: center top;
    mask-image: linear-gradient(90deg, transparent 0%, black 25%, black 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 25%, black 100%);
  }

  .side-marker {
    position: absolute;
    left: var(--sp-7);
    bottom: var(--sp-8);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0.6;
    z-index: 2;
  }

  .hero-content {
    grid-column: 1;
    padding: 0 var(--sp-7) var(--sp-10) var(--container-padding);
    position: relative;
    z-index: 2;
    max-width: 640px;
  }

  .eyebrow {
    margin-bottom: var(--sp-6);
  }

  .hero-title {
    margin-bottom: var(--sp-6);
  }

  .hero-lead {
    font-size: var(--fs-md);
    line-height: 1.5;
    max-width: 30rem;
    margin-bottom: var(--sp-8);
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 0;
      padding-top: var(--sp-11);
    }

    .hero-image {
      position: relative;
      width: 100%;
      height: 60vh;
      min-height: 360px;
      mask-image: linear-gradient(180deg, black 0%, black 70%, transparent 100%);
      -webkit-mask-image: linear-gradient(180deg, black 0%, black 70%, transparent 100%);
    }

    .hero-content {
      grid-column: 1;
      padding: var(--sp-8) var(--container-padding) var(--sp-9);
      max-width: none;
    }

    .side-marker {
      display: none;
    }
  }

  /* SERVICES */
  .services {
    padding-block: var(--sp-10);
    border-top: 1px solid var(--line);
  }

  .section-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-8);
    margin-bottom: var(--sp-10);
    align-items: end;
  }

  .section-title {
    font-size: var(--fs-2xl);
    line-height: 1;
  }

  .section-intro {
    font-size: var(--fs-base);
    line-height: 1.7;
    max-width: 32rem;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  @media (max-width: 900px) {
    .section-header {
      grid-template-columns: 1fr;
      gap: var(--sp-4);
      margin-bottom: var(--sp-8);
    }

    .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
