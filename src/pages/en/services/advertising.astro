---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import Section from '../../../components/Section.astro';
import Button from '../../../components/Button.astro';
import SampleList from '../../../components/SampleList.astro';
import { advertisingSamples } from '../../../data/samples/advertising';
---

<BaseLayout
  title="Advertising — Momchil Stepanov"
  description="Voice Over for TV and radio advertising, jingles, short and long formats. Track record with Bulgarian and international brands."
  lang="en"
  canonicalPath="/en/services/advertising"
>
  <Section as="article">
    <Container>
      <header class="page-header reveal">
        <p class="eyebrow eyebrow--marked">Services · Advertising</p>
        <h1>Advertising</h1>
        <p class="lead muted">
          Voice Over for TV and radio advertising, jingles, short and long formats. Experience with Bulgarian and international brands, across a wide register of tones and characters.
        </p>
      </header>

      <div class="content-grid">
        <section class="reveal">
          <h2>Formats</h2>
          <ul class="bullets">
            <li>TV commercials (15 / 20 / 30 / 60 sec)</li>
            <li>Radio commercials and spots</li>
            <li>Online promo and pre-roll</li>
            <li>Jingles and brand tags</li>
            <li>Short-form social video</li>
            <li>Brand campaigns, multi-spot</li>
          </ul>
        </section>

        <section class="reveal">
          <h2>Range</h2>
          <p class="muted">
            From warm and trusting to energetic and dynamic. From ironic conversational to cinematic dramatic. The voice adapts to the brand brief, not the other way around.
          </p>

          <h2>Languages</h2>
          <p class="muted">Bulgarian (native). English (professional VO).</p>
        </section>
      </div>

      <section class="process reveal">
        <h2>Process</h2>
        <ol class="process-list">
          <li>
            <span class="step-num">01</span>
            <div>
              <h3>Brief</h3>
              <p class="muted">Script, references, technical specs, deadline.</p>
            </div>
          </li>
          <li>
            <span class="step-num">02</span>
            <div>
              <h3>Test recording</h3>
              <p class="muted">When needed — short sample to approve tone and character.</p>
            </div>
          </li>
          <li>
            <span class="step-num">03</span>
            <div>
              <h3>Recording</h3>
              <p class="muted">Final recording at studio quality, multiple takes for selection.</p>
            </div>
          </li>
          <li>
            <span class="step-num">04</span>
            <div>
              <h3>Delivery</h3>
              <p class="muted">WAV / MP3 / AAF to spec. Pickups where reasonably required.</p>
            </div>
          </li>
        </ol>
      </section>

      <section class="samples reveal" aria-labelledby="samples-heading">
        <header class="samples-header">
          <h2 id="samples-heading">Selected work</h2>
          <p class="muted">
            A short selection of recordings. Click a row to expand the player.
          </p>
        </header>
        <SampleList samples={advertisingSamples} lang="en" listId="advertising-en" />
      </section>

      <div class="cta-row reveal">
        <Button href="/en/contact" variant="primary">Advertising inquiry</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-header { max-width: 820px; margin-bottom: var(--sp-9); }
  .page-header h1 { margin-block: var(--sp-3) var(--sp-5); }
  .lead { font-size: var(--fs-md); }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
    margin-bottom: var(--sp-9);
  }
  @media (max-width: 767px) {
    .content-grid { grid-template-columns: 1fr; gap: var(--sp-6); }
  }
  .content-grid h2 { font-size: var(--fs-lg); margin-bottom: var(--sp-4); }
  .content-grid h2:not(:first-of-type) { margin-top: var(--sp-6); }

  .bullets { display: grid; gap: var(--sp-2); }
  .bullets li {
    padding-left: var(--sp-5);
    position: relative;
    color: var(--muted);
  }
  .bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--fg);
  }

  .process h2 { margin-bottom: var(--sp-6); }
  .process-list { display: grid; gap: var(--sp-5); max-width: 720px; }
  .process-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-5);
    align-items: start;
    padding-bottom: var(--sp-5);
    border-bottom: 1px solid var(--line);
  }
  .process-list li:last-child { border-bottom: none; }
  .step-num {
    font-family: var(--font-serif);
    font-size: var(--fs-xl);
    color: var(--muted);
    font-style: italic;
  }
  .process-list h3 { font-size: var(--fs-md); margin-bottom: var(--sp-2); }

  .samples { margin-top: var(--sp-9); }
  .samples-header { margin-bottom: var(--sp-6); max-width: 60ch; }
  .samples-header h2 { font-size: var(--fs-2xl); margin-bottom: var(--sp-3); }

  .cta-row { margin-top: var(--sp-9); }
</style>
