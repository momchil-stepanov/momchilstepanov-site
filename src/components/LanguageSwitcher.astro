---
import { getLangFromUrl, getAlternatePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const targetLang = lang === 'bg' ? 'en' : 'bg';
const targetPath = getAlternatePath(Astro.url.pathname, targetLang);
---

<div class="lang">
  <a
    href={targetPath === Astro.url.pathname ? Astro.url.pathname : Astro.url.pathname}
    aria-current="true"
    class="lang-item is-active"
    hreflang={lang}
  >
    {lang.toUpperCase()}
  </a>
  <span class="lang-divider" aria-hidden="true">/</span>
  <a href={targetPath} class="lang-item" hreflang={targetLang}>
    {targetLang.toUpperCase()}
  </a>
</div>

<style>
  .lang {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--fg);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .lang-item {
    opacity: 0.5;
    transition: opacity var(--t-fast);
    color: inherit;
  }

  .lang-item.is-active {
    opacity: 1;
    pointer-events: none;
  }

  .lang-item:hover {
    opacity: 1;
  }

  .lang-divider {
    opacity: 0.4;
  }
</style>
