---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Section from '../../components/Section.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<BaseLayout
  title="Contact — Momchil Stepanov"
  description="Inquiry for Voice Over, audiobook or dubbing projects. Pricing is provided individually based on project scope and rights."
  lang="en"
  canonicalPath="/en/contact"
>
  <Section as="article">
    <Container>
      <header class="page-header reveal">
        <p class="eyebrow">Contact</p>
        <h1>Inquiry</h1>
        <p class="lead muted">
          Pricing is provided individually, based on scope, media usage and territory. For the fastest response, complete the form below with basic project information.
        </p>
      </header>

      <div class="contact-grid">
        <div class="form-col reveal">
          <ContactForm />
        </div>

        <aside class="contact-meta reveal">
          <h2 class="meta-heading">Information</h2>
          <dl class="meta-list">
            <div>
              <dt>Based in</dt>
              <dd>Sofia, Bulgaria</dd>
            </div>
            <div>
              <dt>Languages</dt>
              <dd>Bulgarian, English</dd>
            </div>
            <div>
              <dt>Pricing</dt>
              <dd>Individual, per project</dd>
            </div>
            <div>
              <dt>Turnaround</dt>
              <dd>By agreement, expedited when possible</dd>
            </div>
          </dl>
        </aside>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-header { max-width: 820px; margin-bottom: var(--sp-9); }
  .page-header h1 { margin-block: var(--sp-3) var(--sp-5); }
  .lead { font-size: var(--fs-md); }

  .contact-grid {
    display: grid; grid-template-columns: 2fr 1fr;
    gap: var(--sp-8);
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: var(--sp-7); }
  }

  .meta-heading { font-size: var(--fs-lg); margin-bottom: var(--sp-5); }

  .meta-list { display: grid; gap: var(--sp-5); margin: 0; }
  .meta-list > div { border-top: 1px solid var(--line); padding-top: var(--sp-3); }
  .meta-list dt {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    font-weight: 500;
    margin-bottom: var(--sp-2);
  }
  .meta-list dd { margin: 0; font-size: var(--fs-base); }
</style>
