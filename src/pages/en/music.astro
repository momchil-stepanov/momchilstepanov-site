---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
---

<BaseLayout
  title="Music — Momchil Stepanov"
  description="Original music, songs from Bulgarian adaptations of animated films, live performance. YouTube channel and selected recordings."
  lang="en"
  canonicalPath="/en/music"
>
  <Section as="article">
    <Container>
      <header class="page-header reveal">
        <p class="eyebrow">Music</p>
        <h1>Original music and songs</h1>
        <p class="lead muted">
          Original music, songs from Bulgarian adaptations of animated films, live performance. The voice as instrument beyond narration.
        </p>
      </header>

      <div class="content-grid">
        <section class="reveal">
          <h2>Areas</h2>
          <ul class="bullets">
            <li>Original music and songs</li>
            <li>Songs from animated films (BG adaptations)</li>
            <li>Live performance</li>
            <li>Collaborations with other artists and authors</li>
          </ul>
        </section>

        <section class="reveal">
          <h2>YouTube channel</h2>
          <p class="muted">
            Video material, live recordings and music projects are published on the YouTube channel. Channel is migrating from @manndalay to @momchilstepanov.
          </p>
          <div style="margin-top: var(--sp-5);">
            <Button href="https://www.youtube.com/@manndalay" variant="ghost" external>
              Visit YouTube channel
            </Button>
          </div>
        </section>
      </div>

      <section class="featured reveal">
        <h2>Selected recordings</h2>
        <div class="tracks-grid">
          <div class="track-placeholder">
            <span class="muted">[Track 01 — TBD]</span>
          </div>
          <div class="track-placeholder">
            <span class="muted">[Track 02 — TBD]</span>
          </div>
          <div class="track-placeholder">
            <span class="muted">[Track 03 — TBD]</span>
          </div>
        </div>
      </section>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-header { max-width: 820px; margin-bottom: var(--sp-9); }
  .page-header h1 { margin-block: var(--sp-3) var(--sp-5); }
  .lead { font-size: var(--fs-md); }
  .content-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: var(--sp-8); margin-bottom: var(--sp-9);
  }
  @media (max-width: 767px) {
    .content-grid { grid-template-columns: 1fr; gap: var(--sp-6); }
  }
  .content-grid h2 { font-size: var(--fs-lg); margin-bottom: var(--sp-4); }
  .bullets { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--sp-2); }
  .bullets li { padding-left: var(--sp-5); position: relative; color: var(--muted); }
  .bullets li::before { content: '—'; position: absolute; left: 0; color: var(--fg); }
  .featured h2 { margin-bottom: var(--sp-5); }
  .tracks-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  @media (max-width: 767px) { .tracks-grid { grid-template-columns: 1fr; } }
  .track-placeholder {
    aspect-ratio: 1 / 1;
    border: 1px dashed var(--line);
    background: var(--bg-elevated);
    color: var(--muted);
    display: flex; align-items: center; justify-content: center;
  }
</style>
